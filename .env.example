# Copy to .env next to app.py. `python app.py` loads it automatically via python-dotenv.
# You can still override with real environment variables or Docker env.

# --- Gradio UI ---
# on|true|1 = require HTTP Basic login for the web UI (off or unset = open UI).
SECURED_MODE=off

# Recommended login when SECURED_MODE=on (avoids clashing with the OS USER variable).
GRADIO_USER=
GRADIO_PASS=

# Fallback if GRADIO_* are empty: USER / PASS (often set USER explicitly in Docker).
# USER=
# PASS=

# --- HTTP API (FastAPI: /api/job*, POST /job, GET /job) ---
# Admin override token. If Authorization Bearer token matches this exactly,
# the request is accepted without JWT decoding.
BEARER_TOKEN=

# JWT auth for non-admin API clients.
# Required when BEARER_TOKEN is not used for a request.
# Realtime clone identity defaults to token sub (fallback uid) when clone_id is omitted.
JWT_SECRET=
JWT_ALGORITHM=HS256

# Multipart field name for POST /job?id=... uploads (muxed MP4). Default: file.
GPU_MULTIPART_FIELD=file

# Per-job uploads and contract jobs under results/api_jobs/...
# API_JOB_DIR=./results/api_jobs

# --- Low-risk performance knobs ---
# Number of CPU worker threads used by optional parallel sections.
CPU_WORKERS=2
# Standard /api/job batch size (UNet/VAE batch in app.py inference).
STANDARD_BATCH_SIZE=8
# Default /api/realtime/job form value for realtime_batch_size.
REALTIME_BATCH_SIZE_DEFAULT=20
# Landmark / bbox detection batch size in musetalk/utils/preprocessing.py.
# Keep conservative by default to avoid VRAM spikes.
LANDMARK_BATCH_SIZE=1

# Overlap audio whisper prep with frame preprocessing in standard jobs.
ENABLE_PARALLEL_AUDIO_FRAME_OVERLAP=on

# Parallelize pad/blend/write in standard jobs. Keep off by default for safety.
ENABLE_PARALLEL_BLEND=off

# Parallelize realtime prepare_material mask/writes. Keep off by default for safety.
ENABLE_PARALLEL_REALTIME_PREP=off

# --- High-impact streaming pipeline (FFmpeg rawvideo pipe; falls back if off) ---
# Standard /api/job + Gradio: skip intermediate result PNGs and imageio frame batch.
ENABLE_STREAMING_STANDARD=off
# Realtime: skip tmp/%08d.png encode pass; pipe blended frames to FFmpeg.
ENABLE_STREAMING_REALTIME=off
# Stdin buffer hint (bytes cap floor 256) for rawvideo writer.
STREAMING_PIPE_BUFFER_FRAMES=4
# Streaming encoder config (applies to standard + realtime streaming paths).
# h264_nvenc preferred on NVIDIA hosts; auto-fallback to libx264 when unavailable.
FFMPEG_VIDEO_ENCODER=h264_nvenc
# NVENC presets: p1..p7 (lower=faster). x264 examples: ultrafast, superfast, veryfast, faster, fast.
FFMPEG_ENCODER_PRESET=p5
# Used when codec is libx264 (lower=better quality, slower).
FFMPEG_ENCODER_CRF=18
# Used when codec is *_nvenc (lower=better quality, slower).
FFMPEG_ENCODER_CQ=23
# If on and NVENC is used, upscale can be fused into encode via scale_cuda.
FFMPEG_USE_GPU_SCALE=on

# --- External CPU mux worker (not read by this app) ---
# Point your mux worker at this MuseTalk instance, e.g.:
# GPU_SERVER_URL=https://musetalk.example.com:7860
