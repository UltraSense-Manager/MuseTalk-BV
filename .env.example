# Copy to .env next to app.py. `python app.py` loads it automatically via python-dotenv.
# You can still override with real environment variables or Docker env.

# --- Gradio UI ---
# on|true|1 = require HTTP Basic login for the web UI (off or unset = open UI).
SECURED_MODE=off

# Recommended login when SECURED_MODE=on (avoids clashing with the OS USER variable).
GRADIO_USER=
GRADIO_PASS=

# Fallback if GRADIO_* are empty: USER / PASS (often set USER explicitly in Docker).
# USER=
# PASS=

# --- HTTP API (FastAPI: /api/job*, POST /job, GET /job) ---
# Admin override token. If Authorization Bearer token matches this exactly,
# the request is accepted without JWT decoding.
BEARER_TOKEN=

# JWT auth for non-admin API clients.
# Required when BEARER_TOKEN is not used for a request.
# Realtime clone identity defaults to token sub (fallback uid) when clone_id is omitted.
JWT_SECRET=
JWT_ALGORITHM=HS256

# Multipart field name for POST /job?id=... uploads (muxed MP4). Default: file.
GPU_MULTIPART_FIELD=file

# Per-job uploads and contract jobs under results/api_jobs/...
# API_JOB_DIR=./results/api_jobs

# --- External CPU mux worker (not read by this app) ---
# Point your mux worker at this MuseTalk instance, e.g.:
# GPU_SERVER_URL=https://musetalk.example.com:7860
